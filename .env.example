# Copy to .env.local and paste values from Firebase Console → Project settings → Your apps → Web app → SDK setup (npm).
# Restart `npm run dev` after changing env vars.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: only if Cloud Functions are not in us-central1
# NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1
