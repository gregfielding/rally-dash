rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Basic helper: any signed-in user
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Admin check via custom claim (matches Firestore pattern)
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // LoRA Ops: Model pack identity face images
    match /modelpacks/{packId}/identities/{identityId}/faces/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // LoRA Ops: Reference library images
    match /reference_library/{category}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Per-identity reference images (saved generations)
    match /identities/{identityId}/reference/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Phase I: identity reference images for Flux 2 multi-reference + future
    // reference-conditioned VTON providers. Operator uploads here via the
    // /lora/identities/{id}/references page; callable registers the file on
    // the identity doc (see addIdentityReferenceImage). Path is enforced
    // server-side to start with rp/identity_references/{identityId}/.
    match /rp/identity_references/{identityId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // LoRA Ops: Training dataset zips (any file under packId)
    match /training_zips/{packId}/{datasetFile} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // LoRA Ops: Dataset images mirrored from generations
    match /datasets/{datasetId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Base photos for mockups
    match /base-photos/{productId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Displacement maps
    match /displacement/{productId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Design files (SVG, PNG, PDF). Write: any authenticated user (Designs UI is app-protected).
    // To restrict to admin/ops only, set custom claims (e.g. admin, ops) and use: allow write: if isAdmin() || request.auth.token.ops == true;
    match /designs/{designId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Mockup images
    match /mockups/{designId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Social/lifestyle images
    match /social/{designId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rally Panties: Blank garment images (style-level front/back AND master-blank variant paths)
    // Variant uploads: rp/blanks/{blankId}/variants/{variantId}/front.jpg (see BlankVariantsManager)
    // Write: any signed-in user (same as /designs/ and /rp/blank_masks/). Firestore rules gate who can edit rp_blanks;
    // Storage isAdmin() would require JWT custom claim admin:true, which ops users often don't have.
    match /rp/blanks/{blankId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Rally Panties: Blank masks (Phase 3 - print region masks)
    // Storage path: rp/blank_masks/{blankId}/{view}/mask.png
    // Write allowed for any authenticated user; Blanks/Masks UI is protected by app-level auth/roles.
    match /rp/blank_masks/{blankId}/{view}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Design Assets: Print pack exports (ZIP files)
    match /print_packs/{designId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Product Mock Generation: Output images
    match /rp/mocks/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Product mockups (Design + Blank → mockup.png)
    match /products/{productId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Bulk design import: temp uploads under each job (path matches Functions + dashboard uploader).
    // Use {allPaths=**} so every segment under the job id is covered (avoids rule mismatch on nested paths).
    // TODO: lifecycle cleanup for stale objects under rp_design_imports/ (scheduled job or TTL).
    match /rp_design_imports/{uid}/{jobId}/{allPaths=**} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
